# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/travel-journal?retryWrites=true&w=majority

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Your GitHub username — only this account can log in
ALLOWED_GITHUB_USERNAME=samsiva-dev
